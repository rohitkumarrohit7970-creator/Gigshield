# Database - PostgreSQL (Neon)
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech/gigshield?sslmode=require

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OpenWeatherMap API (optional - for real weather data)
OPENWEATHERMAP_API_KEY=your-api-key-here

# Razorpay Payment (optional - for real payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Twilio WhatsApp (optional - for notifications)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token